{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpulse.local/protocol/agent-event.schema.json",
  "title": "AgentPulse Agent Event",
  "type": "object",
  "required": ["session_id", "agent", "cwd", "phase"],
  "properties": {
    "session_id": { "type": "string", "minLength": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "cwd": { "type": "string", "minLength": 1 },
    "title": { "type": ["string", "null"] },
    "phase": {
      "type": "string",
      "enum": [
        "idle",
        "preparing",
        "running",
        "waiting_for_action",
        "done",
        "warning",
        "failed",
        "paused",
        "offline"
      ]
    },
    "detail": { "type": ["string", "null"] },
    "pid": { "type": ["integer", "null"], "minimum": 0 },
    "tty": { "type": ["string", "null"] },
    "terminal_bundle_id": { "type": ["string", "null"] },
    "terminal_process": { "type": ["string", "null"] },
    "occurred_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
